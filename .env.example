# Copie este arquivo para .env.local e preencha com valores reais.
# .env.local é ignorado pelo git (.gitignore) — nunca commitar chaves de verdade.

# --- Supabase --- (Project Settings > API, https://supabase.com/dashboard)
# URL do projeto, ex: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Chave "anon/public" — segura para expor no client, o RLS quem protege os dados.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave "service_role" — ignora TODO o RLS. NUNCA prefixar com NEXT_PUBLIC_.
# Só pode ser lida dentro de app/api/** (Route Handlers), nunca em Client Components.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (OCR) --- (https://aistudio.google.com/apikey)
# Free tier, modelo Flash com visão: custo zero até ~1.500 leituras/dia.
# Atenção: NÃO habilitar billing no projeto Google do LuckTank, senão o free tier some.
# Usada só no servidor (lib/gemini/client.ts, chamado a partir de Route Handlers).
GEMINI_API_KEY=

# --- Upstash Redis (rate limit) --- (https://console.upstash.com)
# Usado em lib/rate-limit.ts pra limitar /api/ocr e /api/abastecimentos por IP.
# Sem essas duas variáveis preenchidas, o rate limit fica inerte (sempre libera)
# — ok em dev local, NÃO ok em produção antes do piloto valer pra usuários reais.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- URL base do deploy ---
# Usada pra montar o link de convite (redirectTo) sem depender do header
# `Host` da requisição (evita host header injection no link mágico de
# convite, que carrega o token de sessão). Preencher em produção com a URL
# real, sem barra no final: https://luck-tank.vercel.app
# Deixe vazio em dev local/preview — cai no fallback automático (host da
# própria requisição).
NEXT_PUBLIC_SITE_URL=

# --- Administração do sistema ---
# E-mails com acesso ao painel de criar empresas (app/(escritorio)/admin-sistema),
# separados por vírgula. Quem NÃO estiver nesta lista não vê o link no menu
# e recebe "sem permissão" se acessar a URL direto — mesmo sendo
# administrador de uma empresa. Nunca hardcoded no código (lib/auth/dono-sistema.ts).
DONO_SISTEMA_EMAILS=
