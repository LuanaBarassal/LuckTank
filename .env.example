# Copie este arquivo para .env.local e preencha com valores reais.
# .env.local é ignorado pelo git (.gitignore) — nunca commitar chaves de verdade.

# --- Supabase --- (Project Settings > API, https://supabase.com/dashboard)
# URL do projeto, ex: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Chave "anon/public" — segura para expor no client, o RLS quem protege os dados.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave "service_role" — ignora TODO o RLS. NUNCA prefixar com NEXT_PUBLIC_.
# Só pode ser lida dentro de app/api/** (Route Handlers), nunca em Client Components.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (OCR) --- (https://aistudio.google.com/apikey)
# Free tier, modelo Flash com visão: custo zero até ~1.500 leituras/dia.
# Atenção: NÃO habilitar billing no projeto Google do LuckTank, senão o free tier some.
# Usada só no servidor (lib/gemini/client.ts, chamado a partir de Route Handlers).
GEMINI_API_KEY=
